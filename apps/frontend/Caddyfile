:80 {
  root * /srv
  encode zstd gzip

  @static_assets path /assets/*
  header @static_assets Cache-Control "public, max-age=31536000, immutable"

  @app_shell not path /assets/*
  header @app_shell Cache-Control "public, max-age=0, must-revalidate"

  try_files {path} /index.html
  file_server
}
