{
  "name": "backend",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts src/worker.ts src/worker-health.ts --target bun --outdir dist",
    "start:bundle": "bun run dist/index.js",
    "start:worker": "bun run dist/worker.js",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "db:generate": "bun drizzle-kit generate",
    "db:migrate": "bun drizzle-kit migrate",
    "db:bootstrap-admin": "bun run src/db/bootstrap-admin.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@libpdf/core": "^0.3.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "nodemailer": "^8.0.3",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^7.0.11",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
