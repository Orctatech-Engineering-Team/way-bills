APP_ENV=production
APP_ORIGIN=https://waybills.orctatech.com
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@postgres-host:5432/waybills
JWT_SECRET=replace-with-a-long-random-secret
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_REPLY_TO=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_STORAGE_PUBLIC_BASE_URL=https://pub-uploads-token.r2.dev
R2_STORAGE_BUCKET=waybill-signatures
R2_DOCUMENT_PUBLIC_BASE_URL=https://pub-documents-token.r2.dev
R2_DOCUMENT_BUCKET=waybill-documents
INVOICE_AUTOMATION_ENABLED=false
INVOICE_AUTOMATION_INTERVAL_MINUTES=15
INVOICE_AUTOMATION_LOOKBACK_WEEKS=8
AUTOMATION_ACTOR_PHONE=
SEED_DEFAULT_PASSWORD=ChangeMe123!
